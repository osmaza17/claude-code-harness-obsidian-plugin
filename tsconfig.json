{
  "compilerOptions": {
    "module": "ESNext",
    "target": "ES2020",
    "moduleResolution": "bundler",
    "allowJs": true,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["DOM", "ES2020"],
    "types": ["node"],
    "strict": false
  },
  "include": ["main.ts", "accounts.ts", "settings-tab.ts", "history.ts", "header.ts", "types.ts", "constants.ts", "utils.ts"]
}
